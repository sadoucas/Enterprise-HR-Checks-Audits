generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum FormStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

enum AuditStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  REPORTED
}

enum WarningType {
  VERBAL
  WRITTEN
  SUSPENSION
  TERMINATION
}

enum WarningStatus {
  ISSUED
  ACKNOWLEDGED
  APPEALED
  RESOLVED
}

enum MessageType {
  ALERT
  NOTIFICATION
  WARNING
  GENERAL
}

enum MessagePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole  @default(EMPLOYEE)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLogin         DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?

  submittedForms    Form[]    @relation("SubmittedBy")
  completedChecklists Checklist[] @relation("CompletedBy")
  verifiedChecklists Checklist[] @relation("VerifiedBy")
  conductedAudits   Audit[]   @relation("ConductedBy")
  issuedWarnings    Warning[] @relation("IssuedBy")
  receivedWarnings  Warning[] @relation("ReceivedBy")
  sentMessages      Message[] @relation("SentBy")
  receivedMessages  MessageRecipient[] @relation("ReceivedBy")
  sentReplies       MessageReply[] @relation("RepliedBy")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Site {
  id          String    @id @default(cuid())
  name        String    @unique
  location    String
  address     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  departments Department[]
  checklists  Checklist[]
  audits      Audit[]

  @@index([name])
}

model Department {
  id          String    @id @default(cuid())
  name        String
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  forms       Form[]

  @@unique([siteId, name])
  @@index([siteId])
}

model Form {
  id                String    @id @default(cuid())
  title             String
  description       String?
  departmentId      String
  department        Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  status            FormStatus @default(DRAFT)
  submittedById     String?
  submittedBy       User?     @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt       DateTime?
  approvedAt        DateTime?
  requiredFields    String[]  // JSON array
  formData          String    // JSON
  signatureRequired Boolean   @default(false)
  signatureData     String?   // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  responses         FormResponse[]

  @@index([departmentId])
  @@index([status])
  @@index([submittedById])
}

model FormResponse {
  id            String    @id @default(cuid())
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  responseData  String    // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([formId])
}

model Checklist {
  id                String    @id @default(cuid())
  title             String
  description       String?
  siteId            String
  site              Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status            ChecklistStatus @default(PENDING)
  completedById     String?
  completedBy       User?     @relation("CompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt       DateTime?
  verifiedById      String?
  verifiedBy        User?     @relation("VerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?
  verificationNotes String?
  requiredFields    String[]  // JSON array
  items             String    // JSON array
  checklistData     String    // JSON
  signatureRequired Boolean   @default(false)
  signatureData     String?   // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  responses         ChecklistResponse[]

  @@index([siteId])
  @@index([status])
  @@index([completedById])
  @@index([verifiedById])
}

model ChecklistResponse {
  id            String    @id @default(cuid())
  checklistId   String
  checklist     Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  responseData  String    // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([checklistId])
}

model Audit {
  id                String    @id @default(cuid())
  title             String
  description       String?
  siteId            String
  site              Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status            AuditStatus @default(SCHEDULED)
  conductedById     String
  conductedBy       User      @relation("ConductedBy", fields: [conductedById], references: [id], onDelete: Restrict)
  scheduledDate     DateTime
  completedAt       DateTime?
  reportedAt        DateTime?
  requiredFields    String[]  // JSON array
  auditData         String    // JSON
  findingsSummary   String?   // JSON: {CRITICAL: 0, HIGH: 0, MEDIUM: 0, LOW: 0}
  reportData        String?   // JSON
  signatureRequired Boolean   @default(false)
  signatureData     String?   // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  responses         AuditResponse[]

  @@index([siteId])
  @@index([status])
  @@index([conductedById])
  @@index([scheduledDate])
}

model AuditResponse {
  id            String    @id @default(cuid())
  auditId       String
  audit         Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)
  responseData  String    // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([auditId])
}

model Warning {
  id                    String    @id @default(cuid())
  title                 String
  description           String
  type                  WarningType
  status                WarningStatus @default(ISSUED)
  issuedById            String
  issuedBy              User      @relation("IssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)
  receivedById          String
  receivedBy            User      @relation("ReceivedBy", fields: [receivedById], references: [id], onDelete: Restrict)
  issuedAt              DateTime  @default(now())
  acknowledgedAt        DateTime?
  appealedAt            DateTime?
  resolvedAt            DateTime?
  acknowledgmentRequired Boolean   @default(true)
  signatureRequired     Boolean   @default(false)
  signatureData         String?   // JSON
  appealReason          String?
  supportingNotes       String?
  resolutionNotes       String?
  outcome               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([issuedById])
  @@index([receivedById])
  @@index([status])
  @@index([type])
  @@index([issuedAt])
}

model Message {
  id            String    @id @default(cuid())
  content       String
  subject       String?
  senderId      String
  sender        User      @relation("SentBy", fields: [senderId], references: [id], onDelete: Restrict)
  messageType   MessageType @default(GENERAL)
  priority      MessagePriority @default(MEDIUM)
  attachments   String?   // JSON array
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  recipients    MessageRecipient[]
  replies       MessageReply[]

  @@index([senderId])
  @@index([messageType])
  @@index([priority])
  @@index([createdAt])
}

model MessageRecipient {
  id             String    @id @default(cuid())
  messageId      String
  message        Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipientId    String
  recipient      User      @relation("ReceivedBy", fields: [recipientId], references: [id], onDelete: Cascade)
  isRead         Boolean   @default(false)
  readAt         DateTime?
  deliveryStatus DeliveryStatus @default(PENDING)
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([messageId, recipientId])
  @@index([recipientId])
  @@index([isRead])
  @@index([deliveryStatus])
}

model MessageReply {
  id          String    @id @default(cuid())
  content     String
  messageId   String
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("RepliedBy", fields: [senderId], references: [id], onDelete: Restrict)
  attachments String?   // JSON array
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([messageId])
  @@index([senderId])
}
