generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum FormStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ChecklistStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole  @default(EMPLOYEE)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLogin         DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?

  submittedForms    Form[]    @relation("SubmittedBy")
  completedChecklists Checklist[] @relation("CompletedBy")
  verifiedChecklists Checklist[] @relation("VerifiedBy")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Site {
  id          String    @id @default(cuid())
  name        String    @unique
  location    String
  address     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  departments Department[]
  checklists  Checklist[]

  @@index([name])
}

model Department {
  id          String    @id @default(cuid())
  name        String
  siteId      String
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  forms       Form[]

  @@unique([siteId, name])
  @@index([siteId])
}

model Form {
  id                String    @id @default(cuid())
  title             String
  description       String?
  departmentId      String
  department        Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  status            FormStatus @default(DRAFT)
  submittedById     String?
  submittedBy       User?     @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt       DateTime?
  approvedAt        DateTime?
  requiredFields    String[]  // JSON array
  formData          String    // JSON
  signatureRequired Boolean   @default(false)
  signatureData     String?   // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  responses         FormResponse[]

  @@index([departmentId])
  @@index([status])
  @@index([submittedById])
}

model FormResponse {
  id            String    @id @default(cuid())
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  responseData  String    // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([formId])
}

model Checklist {
  id                String    @id @default(cuid())
  title             String
  description       String?
  siteId            String
  site              Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  status            ChecklistStatus @default(PENDING)
  completedById     String?
  completedBy       User?     @relation("CompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt       DateTime?
  verifiedById      String?
  verifiedBy        User?     @relation("VerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?
  verificationNotes String?
  requiredFields    String[]  // JSON array
  items             String    // JSON array
  checklistData     String    // JSON
  signatureRequired Boolean   @default(false)
  signatureData     String?   // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  responses         ChecklistResponse[]

  @@index([siteId])
  @@index([status])
  @@index([completedById])
  @@index([verifiedById])
}

model ChecklistResponse {
  id            String    @id @default(cuid())
  checklistId   String
  checklist     Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  responseData  String    // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([checklistId])
}
