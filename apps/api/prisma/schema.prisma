generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum FormStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole  @default(EMPLOYEE)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLogin         DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?

  // Relations
  submittedForms    Form[]    @relation("SubmittedBy")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Department {
  id          String    @id @default(cuid())
  name        String
  siteId      String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  forms       Form[]

  @@unique([siteId, name])
  @@index([siteId])
}

model Form {
  id                String    @id @default(cuid())
  title             String
  description       String?
  departmentId      String
  department        Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  status            FormStatus @default(DRAFT)
  submittedById     String?
  submittedBy       User?     @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt       DateTime?
  approvedAt        DateTime?
  requiredFields    String[]  // JSON array of required field names
  formData          String    // JSON blob for form responses
  signatureRequired Boolean   @default(false)
  signatureData     String?   // JSON blob for signature
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  responses         FormResponse[]

  @@index([departmentId])
  @@index([status])
  @@index([submittedById])
}

model FormResponse {
  id            String    @id @default(cuid())
  formId        String
  form          Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  responseData  String    // JSON blob
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([formId])
}
